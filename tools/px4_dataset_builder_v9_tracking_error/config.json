{
  "dataset_name": "px4_phase1_recovery_tracking_error_dataset_v9",
  "source_run_glob": "~/px4_datasets/px4_phase1_standard_vtol_recovery_tracking_error_dataset_v16_*",
  "output_root": "~/px4_datasets/processed",
  "max_runs": null,
  "filters": {
    "min_relative_altitude_m": 10.0,
    "max_relative_altitude_m": 40.0,
    "max_abs_roll_deg": 25.0,
    "max_abs_pitch_deg": 25.0,
    "max_abs_body_rate_deg_s": 120.0,
    "min_dt_s": 0.025,
    "max_dt_s": 0.075,
    "require_quality_ok_basic": true,
    "require_aux_targets": true,
    "min_aux_notna_fraction": 0.95,
    "dx_limits": {
      "local_north_m": 0.25,
      "local_east_m": 0.25,
      "relative_altitude_m": 0.40,
      "vel_north_m_s": 0.40,
      "vel_east_m_s": 0.40,
      "vel_down_m_s": 0.35,
      "roll_deg": 1.20,
      "pitch_deg": 1.20,
      "yaw_deg": 1.60,
      "roll_rate_rad_s": 0.25,
      "pitch_rate_rad_s": 0.25,
      "yaw_rate_rad_s": 0.15
    },
    "aux_abs_limits": {
      "derived_accel_north_m_s2": 5.0,
      "derived_accel_east_m_s2": 5.0,
      "derived_accel_down_m_s2": 4.0,
      "derived_roll_accel_rad_s2": 4.0,
      "derived_pitch_accel_rad_s2": 4.0,
      "derived_yaw_accel_rad_s2": 3.0
    }
  },
  "split": {
    "seed": 7,
    "train_fraction": 0.72,
    "val_fraction": 0.14,
    "test_fraction": 0.14,
    "block_size_samples": 160,
    "val_scenarios": [],
    "test_scenarios": ["C09_mixed_position_sequence"],
    "hard_scenario_test_fraction": 0.25
  },
  "columns": {
    "state": [
      "local_north_m",
      "local_east_m",
      "relative_altitude_m",
      "vel_north_m_s",
      "vel_east_m_s",
      "vel_down_m_s",
      "roll_deg",
      "pitch_deg",
      "yaw_deg",
      "roll_rate_rad_s",
      "pitch_rate_rad_s",
      "yaw_rate_rad_s"
    ],
    "action": [
      "ref_north_m",
      "ref_east_m",
      "ref_down_m",
      "ref_north_m_s",
      "ref_east_m_s",
      "ref_down_m_s",
      "ref_yaw_deg",
      "ref_yaw_offset_deg"
    ],
    "aux_target": [
      "derived_accel_north_m_s2",
      "derived_accel_east_m_s2",
      "derived_accel_down_m_s2",
      "derived_roll_accel_rad_s2",
      "derived_pitch_accel_rad_s2",
      "derived_yaw_accel_rad_s2"
    ],
    "optional_aux_target": []
  }
}
