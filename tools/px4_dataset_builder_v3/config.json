{
  "dataset_name": "px4_phase1_rate_dynamics_dataset_v3_imu_aux",
  "source_run_glob": "~/px4_datasets/px4_phase1_standard_vtol_nominal_rate_dataset_v13_imu_aux_*",
  "output_root": "~/px4_datasets/processed",
  "max_runs": null,
  "filters": {
    "min_relative_altitude_m": 10.0,
    "max_relative_altitude_m": 35.0,
    "max_abs_roll_deg": 25.0,
    "max_abs_pitch_deg": 25.0,
    "max_abs_body_rate_deg_s": 120.0,
    "min_dt_s": 0.025,
    "max_dt_s": 0.075,
    "require_quality_ok_basic": true,
    "require_aux_targets": true,
    "min_aux_notna_fraction": 0.95
  },
  "split": {
    "seed": 7,
    "train_fraction": 0.7,
    "val_fraction": 0.15,
    "test_fraction": 0.15,
    "val_scenarios": [],
    "test_scenarios": ["N11_mixed_sequence"]
  },
  "columns": {
    "state": [
      "relative_altitude_m",
      "vel_north_m_s",
      "vel_east_m_s",
      "vel_down_m_s",
      "roll_deg",
      "pitch_deg",
      "yaw_deg",
      "roll_rate_rad_s",
      "pitch_rate_rad_s",
      "yaw_rate_rad_s"
    ],
    "action": [
      "ref_roll_rate_rad_s",
      "ref_pitch_rate_rad_s",
      "ref_yaw_rate_rad_s",
      "ref_thrust"
    ],
    "aux_target": [
      "derived_accel_north_m_s2",
      "derived_accel_east_m_s2",
      "derived_accel_down_m_s2",
      "derived_roll_accel_rad_s2",
      "derived_pitch_accel_rad_s2",
      "derived_yaw_accel_rad_s2"
    ],
    "optional_aux_target": [
      "imu_accel_forward_m_s2",
      "imu_accel_right_m_s2",
      "imu_accel_down_m_s2",
      "imu_angular_rate_forward_rad_s",
      "imu_angular_rate_right_rad_s",
      "imu_angular_rate_down_rad_s"
    ]
  }
}
